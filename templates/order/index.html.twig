{% extends 'base.html.twig' %}

{% block title %}Validation - Panier{% endblock %}

{% block stylesheets %}
    <style>
        /* Tailles de police globales pour le checkout */
        .checkout-page {
            font-size: 1.2rem; /* Augmentation générale de la base */
        }

        .checkout-card {
            background: #fff;
            border-radius: 16px;
        }

        /* Labels des adresses et transporteurs (Symfony Widgets) */
        .custom-form-radio label {
            font-size: 1.2rem !important; /* Texte des adresses bien plus grand */
            font-weight: 500;
            line-height: 1.5;
            /*padding: 10px 0;*/
            cursor: pointer;
            display: inline-block;
        }

        /* Espacement entre les lignes de choix */
        .custom-form-radio br {
            display: block;
            content: "";
            margin-top: 10px;
        }

        /* Prix final */
        .text-primary {
            color: #ffab09 !important; /* Violet Wildberries */
        }

        .fs-3 {
            font-size: 1.85rem !important; /* Prix total imposant */
        }

        /* Bouton principal */
        .btn-wb-checkout {
            background-color: #ffab09;
            color: #fff;
            border-radius: 12px;
            letter-spacing: 0.5px;
            transition: transform 0.2s ease;
        }

        .btn-wb-checkout:hover {
            background-color: #ffab09;
            transform: scale(1.01);
        }

        .small-caps {
            letter-spacing: 1px;
            font-size: 0.85rem;
        }

        /* Optimisation mobile */
        @media (max-width: 576px) {
            .fs-3 {
                font-size: 1.5rem !important;
            }

            .custom-form-radio label {
                font-size: 1rem !important;
            }
        }
    </style>
{% endblock %}

