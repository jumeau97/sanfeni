    <section class="checkout-recap py-5 bg-light">
        <div class="container">
            <h2 class="fw-bold mb-5 fs-2">Vérification de votre commande</h2>

            <div class="row g-4">
                <div class="col-lg-7">
                    <div class="checkout-card mb-4 shadow-sm border-0">
                        <div class="card-header-wb py-3 px-4">
                            <i class="bi bi-geo-alt-fill fs-4 text-primary me-2"></i>
                            <h5 class="mb-0 fs-4 fw-bold">Adresse de livraison</h5>
                        </div>
                        <div class="card-body-wb p-4">
                            <div class="delivery-box p-3 rounded-3 bg-light border">
                                <p class="fs-5 mb-0 text-dark" style="line-height: 1.6;">
                                    {{ delivery|raw }}
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="checkout-card shadow-sm border-0">
                        <div class="card-header-wb py-3 px-4">
                            <i class="bi bi-truck fs-4 text-primary me-2"></i>
                            <h5 class="mb-0 fs-4 fw-bold">Mode d'expédition</h5>
                        </div>
                        <div class="card-body-wb p-4">
                            <div class="carrier-box">
                                <h5 class="fw-bold fs-5 text-primary mb-1">{{ carrier.name }}</h5>
                                <p class="text-muted fs-6 mb-2">{{ carrier.description }}</p>
                                <span
                                    class="badge bg-primary fs-6 px-3 py-2">{{ carrier.price|format_currency('XOF') }}</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="sticky-top" style="top: 20px;">
                        <div class="checkout-card shadow-sm border-0">
                            <div class="card-body-wb p-4">
                                <h4 class="fw-bold mb-4 fs-3">Récapitulatif financier</h4>

                                <ul class="list-unstyled">
                                    {% set total = 0 %}
                                    {% for product in cart %}
                                        {% if product.product.offPercent is defined and product.product.offPercent > 0 %}
                                            {% set unitPrice = (product.product.price / 100) * (1 - (product.product.offPercent / 100)) %}
                                        {% else %}
                                            {% set unitPrice = (product.product.price / 100) %}
                                        {% endif %}
                                        {% set rowTotal = unitPrice * product.quantity %}
                                        {% set total = total + rowTotal %}

                                        <li class="d-flex justify-content-between mb-3">
                                            <div class="pe-3">
                                                <h6 class="fw-bold mb-0 fs-5">{{ product.product.name }}</h6>
                                                <span
                                                    class="text-muted fw-medium">Quantité : {{ product.quantity }}</span>
                                            </div>
                                            <span
                                                class="fw-bold fs-5 text-dark">{{ rowTotal|format_currency('XOF') }}</span>
                                        </li>
                                    {% endfor %}
                                </ul>

                                <hr class="my-4">

                                <div class="d-flex justify-content-between mb-2">
                                    <span class="fs-5 text-muted">Sous-total produits</span>
                                    <span class="fs-5 fw-bold">{{ total|format_currency('XOF') }}</span>
                                </div>
                                <div class="d-flex justify-content-between mb-4">
                                    <span class="fs-5 text-muted">Frais de port</span>
                                    <span class="fs-5 fw-bold">{{ carrier.price|format_currency('XOF') }}</span>
                                </div>

                                <div
                                    class="total-banner p-3 rounded-3 mb-4 d-flex justify-content-between align-items-center">
                                    <span class="fs-4 fw-bold text-white">TOTAL À PAYER</span>
                                    <span
                                        class="fs-2 fw-bold text-white">{{ (total + carrier.price)|format_currency('XOF') }}</span>
                                </div>

                                {{ form_start(form, {'action': path('stripe_create_session', {'reference':reference}),'attr': { 'data-turbo': 'false' }}) }}
                                <h5 class="fw-bold mb-3 fs-5">Moyen de paiement</h5>
                                <div class="payment-methods mb-4">
                                    {% for label, value in field_choices(form.payMethod) %}
                                        {% set inputId = field_id(form.payMethod) ~ '_' ~ loop.index %}
                                        <div class="payment-item mb-2">
                                            <input type="radio" class="btn-check"
                                                   name="{{ field_name(form.payMethod) }}" id="{{ inputId }}"
                                                   value="{{ value }}" autocomplete="off" required>
                                            <label class="btn btn-outline-primary w-100 text-start p-3 fw-bold fs-6"
                                                   for="{{ inputId }}">
                                                <i class="bi bi-credit-card-2-back me-2"></i> {{ label }}
                                            </label>
                                        </div>
                                    {% endfor %}
                                </div>

                                <button type="submit" class="btn btn-wb-pay w-100 py-3 fs-4 fw-bold shadow">
                                    Confirmer et Payer
                                </button>
                                {{ form_end(form) }}

                                <p class="text-center text-muted small mt-3">
                                    <i class="bi bi-shield-lock-fill me-1"></i> Transaction sécurisée par Stripe
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!--------------- checkout-section-end---------------->
{% endblock %}

