    <style>
        :root {
            --wb-purple: #FFA500FF;
            --wb-purple-hover: #eea41e;
        }

        /* Grille et Conteneur */
        .product-card {
            display: flex;
            flex-direction: column;
        }

        .img-container {
            position: relative;
            border-radius: 12px;
            overflow: hidden;
            background-color: #f1f1f1;
        }

        .product-img {
            width: 100%;
            aspect-ratio: 3 / 4; /* Format vertical type marketplace */
            object-fit: cover;
            transition: transform 0.3s ease;
        }

        .product-card:hover .product-img {
            transform: scale(1.05);
        }

        /* Badges */
        .discount-badge {
            position: absolute;
            bottom: 8px;
            left: 8px;
            background-color: #ff3b30;
            color: white;
            font-size: 0.75rem;
            font-weight: bold;
            padding: 2px 8px;
            border-radius: 4px;
        }

        .wishlist-btn {
            position: absolute;
            top: 8px;
            right: 8px;
            background: rgba(255, 255, 255, 0.7);
            border: none;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #333;
        }

        /* Typographie */
        .price-current {
            color: #ff3b30;
            font-size: 1.5rem;
            font-weight: 800;
        }

        .price-old {
            color: #999;
            text-decoration: line-through;
            font-size: 0.9rem;
        }

        /* Titre du produit : Augmenté et plus d'espace */
        .product-title {
            display: block;
            font-size: 1.2rem; /* Taille standard bien lisible */
            line-height: 1.3;
            font-weight: 500;
            margin-top: 6px;
            height: 2.6em; /* Fixe la hauteur pour 2 lignes */
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .brand-name {
            display: block;
            font-size: 0.85rem;
            line-height: 1.2;
            margin-top: 4px;
            display: -webkit-box;
            -webkit-line-clamp: 2; /* Limite à 2 lignes */
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .btn-wb {
            background-color: #FFA500FF; /* Violet Wildberries */
            color: white;
            border: none;
            border-radius: 12px; /* Coins arrondis modernes */
            padding: 10px 15px;
            font-size: 1.3rem;
            transition: all 0.2s ease-in-out;
            box-shadow: 0 4px 10px rgba(234, 62, 46, 0.2);
        }

        .btn-wb:hover {
            background-color: #FFA500FF;
            color: white;
            transform: translateY(-2px); /* Petit effet de levier au survol */
            box-shadow: 0 6px 15px rgba(239, 59, 42, 0.3);
        }

        .btn-wb:active {
            transform: translateY(0);
        }

        /* Ajustement pour les petits écrans */
        @media (max-width: 576px) {
            .btn-wb {
                font-size: 1rem;
                padding: 8px 10px;
            }

            .btn-wb span {
                /* On peut cacher le texte long sur très petit mobile si besoin */
                /* display: none; */
            }
        }
    </style>
    <style>
        /* Animation de chargement */
        @keyframes shimmer {
            0% {
                background-position: -468px 0;
            }
            100% {
                background-position: 468px 0;
            }
        }

        .skeleton-img, .skeleton-text, .skeleton-btn {
            background: #f6f7f8;
            background-image: linear-gradient(to right, #f6f7f8 0%, #edeef1 20%, #f6f7f8 40%, #f6f7f8 100%);
            background-repeat: no-repeat;
            background-size: 800px 100%;
            display: inline-block;
            position: relative;
            animation: shimmer 1.2s infinite linear;
            border-radius: 8px;
        }

        .skeleton-img {
            width: 100%;
            aspect-ratio: 3/4;
        }

        .skeleton-price {
            width: 60%;
            height: 24px;
        }

        .skeleton-title {
            width: 100%;
            height: 14px;
        }

        .skeleton-btn {
            width: 100%;
            height: 40px;
            border-radius: 10px;
        }
    </style>
    {# Champs de recherche au niveau du header #}
    <style>
        /* Container de recherche */
        .search-section-wb {
            max-width: 900px;
            margin: 0 auto;
        }

        .search-section-wb .input-group {
            background-color: #fff;
            border-radius: 50px; /* Barre très arrondie style pilule */
            /* L'espace (marge interne) qui entoure le bouton bleu */
            padding: 6px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            border: 1px solid #e0e0e0;
            transition: all 0.2s ease;
            align-items: center; /* Centre verticalement l'input et le bouton */
        }

        /* Effet au focus */
        .search-section-wb .input-group:focus-within {
            border-color: #FFA500FF;
            box-shadow: 0 4px 25px rgba(13, 110, 253, 0.15);
        }

        /* L'input texte */
        .search-section-wb .form-control {
            border: none !important;
            background: transparent;
            height: 40px;
            font-size: 1rem;
            color: #333;
            padding-left: 20px;
        }

        .search-section-wb .form-control:focus {
            box-shadow: none;
        }

        /* Le bouton RECHERCHER (Style "Flottant" Arrondi) */
        .btn-search-wb {
            background-color: #082C6A;
            color: #ffffff;
            border: none;
            font-weight: 600;
            font-size: 1.4rem;
            /* Arrondi complet pour faire un bouton ovale à l'intérieur */
            border-radius: 40px !important;
            padding: 10px 30px;
            height: 100%; /* S'adapte à la hauteur du padding parent */
            transition: all 0.3s ease;
        }

        .btn-search-wb:hover {
            background-color: #FFA500FF;
            color: #ffffff;
            box-shadow: 0 4px 12px rgba(232, 164, 60, 0.3);
        }

        /* Responsive Mobile */
        @media (max-width: 576px) {
            .search-section-wb .input-group {
                padding: 4px;
                border-radius: 30px;
            }

            .search-section-wb .form-control {
                height: 35px;
                font-size: 0.85rem;
            }

            .btn-search-wb {
                padding: 8px 15px;
                font-size: 0.85rem;
            }
        }
    </style>

    <style>
