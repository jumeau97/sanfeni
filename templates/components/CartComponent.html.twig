{# Le 'attributes' doit englober toute la zone à rafraîchir (le tableau et les totaux) #}
<div {{ attributes }}>

    <div class="cart-section elevated-card">
        {% if cartItems is not empty %}
            <table class="w-100">
                <tbody>
                <tr class="table-row table-top-row">
                    {# ... Vos en-têtes ... #}
                </tr>

                {% for cartItem in cartItems %}
                    {{ component('CartItemRowComponent', {
                        productId: cartItem.product.id,
                        quantity: cartItem.quantity,
                        key: cartItem.product.id,
                    }) }}
                {% endfor %}
                </tbody>
            </table>

            {# Affichage du Total Général (Uniquement si plein) #}
            <div class="cart-summary-box mt-4">
                <div class="d-flex justify-content-end align-items-center gap-3">
                    <h4 class="mb-0 text-muted">Total Général :</h4>
                    <h2 class="mb-0 fw-bold" id="grand-total-amount" style="color: #082C6A;">
                        {{ this.grandTotal|format_currency('XOF') }}
                    </h2>
                </div>
                <div class="text-end mt-4">
                    <a href="{{ path('app_order') }}" class="shop-btn-lg">
                        Commander <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>

        {% else %}
            {# MESSAGE PANIER VIDE (Centré et Élégant) #}
            <div class="empty-cart-full-page">
                <div class="empty-illustration">
                    <div class="circle-bg">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                </div>
                <h2 class="fw-bold mt-4">Votre panier est vide...</h2>
                <p class="text-muted mb-4">Découvrez nos nouveautés et trouvez votre coup de cœur !</p>
                <a href="{{ path('app_home') }}" class="shop-btn-primary px-5 py-3 rounded-pill">
                    Continuer mes achats
                </a>
            </div>
        {% endif %}
    </div>

</div>
