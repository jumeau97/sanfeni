{% extends 'base.html.twig' %}

{% block title %}Hello AccountController!{% endblock %}

{% block stylesheets %}
    <style>
        /* Style des cartes de commandes */
        .order-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            border: 1px solid transparent;
        }

        .order-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.08) !important;
            border-color: rgba(138, 63, 252, 0.2);
        }

        /* Typographie augmentée */
        .small-caps {
            font-size: 0.75rem;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            font-weight: 700;
        }

        .fs-5 { font-size: 1.15rem !important; }
        .fs-4 { font-size: 1.4rem !important; }

        /* Badges de statut doux */
        .bg-soft-success {
            background-color: #e8f5e9;
            color: #2e7d32;
        }

        /* Bordures verticales sur desktop */
        @media (min-width: 768px) {
            .border-start-md {
                border-left: 1px solid #eee !important;
            }
        }

        /* Bouton personnalisé */
        .btn-outline-primary {
            border-color: var(--wb-purple);
            color: var(--wb-purple);
        }

        .btn-outline-primary:hover {
            background-color: var(--wb-purple);
            border-color: var(--wb-purple);
            color: white;
        }

        /* Ajustement Mobile */
        @media (max-width: 576px) {
            .order-card {
                padding: 20px !important;
            }
            .order-card .btn {
                width: 100%;
                margin-top: 10px;
            }
        }
    </style>
{% endblock %}

