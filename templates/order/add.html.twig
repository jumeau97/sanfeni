{% extends 'base.html.twig' %}

{% block javascripts %}
    <script src="https://js.stripe.com/v3/"></script>
{% endblock %}

{% block stylesheets %}
    <style>
        :root {
            --wb-blue: #FFA500FF;
            --wb-blue-dark: #d7780b;
        }


        /* Cartes */
        .checkout-card {
            background: #ffffff;
            border-radius: 20px;
        }

        .card-header-wb {
            border-bottom: 1px solid #f0f0f0;
        }

        /* Bloc Total */
        .total-banner {
            background: linear-gradient(135deg, var(--wb-blue), #b63518);
            box-shadow: 0 4px 15px rgba(13, 110, 253, 0.3);
        }

        /* Bouton de paiement XXL */
        .btn-wb-pay {
            background-color: var(--wb-blue);
            color: white;
            border: none;
            border-radius: 15px;
            transition: all 0.3s ease;
        }

        .btn-wb-pay:hover {
            background-color: var(--wb-blue-dark);
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(253, 185, 13, 0.4);
        }

        /* Radio Buttons personnalisés pour le paiement */
        .payment-item .btn-check:checked + .btn-outline-primary {
            background-color: var(--wb-blue);
            color: white;
            border-color: var(--wb-blue);
        }

        .payment-item .btn-outline-primary {
            border: 2px solid #eee;
            color: #444;
            border-radius: 12px;
        }

        /* Typographie augmentée */
        .fs-2 {
            font-size: 2.2rem !important;
        }

        .fs-4 {
            font-size: 1.5rem !important;
        }

        .fs-5 {
            font-size: 1.25rem !important;
        }

        .fs-6 {
            font-size: 1.1rem !important;
        }

        /* Responsive */
        @media (max-width: 576px) {
            .fs-2 {
                font-size: 1.6rem !important;
            }

            .total-banner .fs-2 {
                font-size: 1.4rem !important;
            }

            .btn-wb-pay {
                font-size: 1.2rem !important;
            }
        }
    </style>
{% endblock %}

