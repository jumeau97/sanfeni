    <section class="checkout-page py-5 bg-light">
        <div class="container">
            <h2 class="fw-bold mb-5 fs-2">Finaliser ma commande</h2> {# Titre agrandi #}

            {{ form_start(form,{action:path('app_order_recap'), 'attr': { 'data-turbo': 'false' }}) }}
            <div class="row g-4">

                <div class="col-lg-7">
                    <div class="checkout-card mb-4 shadow-sm border-0">
                        <div class="card-header-wb py-3">
                            <i class="bi bi-geo-alt-fill me-2 fs-5 text-primary"></i>
                            <h5 class="mb-0 fs-5 fw-bold">1. Adresse de livraison</h5>
                        </div>
                        <div class="card-body-wb p-4">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <label class="fw-bold text-muted text-uppercase small-caps">Sélectionnez une
                                    adresse</label>
                                <a href="{{ path('app_account_address') }}"
                                   class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold">
                                    + Ajouter
                                </a>
                            </div>
                            <div class="custom-form-radio fs-6"> {# fs-6 pour les labels d'adresse #}
                                {{ form_widget(form.adresses) }}
                            </div>
                        </div>
                    </div>

                    <div class="checkout-card shadow-sm border-0">
                        <div class="card-header-wb py-3">
                            <i class="bi bi-truck me-2 fs-5 text-primary"></i>
                            <h5 class="mb-0 fs-5 fw-bold">2. Mode de livraison</h5>
                        </div>
                        <div class="card-body-wb p-4">
                            <div class="custom-form-radio fs-6">
                                {{ form_widget(form.carriers) }}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="sticky-top" style="top: 20px;">
                        <div class="checkout-card shadow-sm border-0 border-top border-primary border-4">
                            <div class="card-body-wb p-4">
                                <h4 class="fw-bold mb-4">Votre panier</h4>

                                <ul class="order-list list-unstyled m-0">
                                    {% set total = 0 %}
                                    {% for product in cart %}
                                        <li class="d-flex justify-content-between align-items-start mb-3 pb-3 border-bottom border-light">
                                            <div class="product-info-mini">
                                                <h6 class="mb-1 fw-bold fs-6">{{ product.product.name }}</h6>
                                                <span class="text-muted fw-medium">Qté : {{ product.quantity }}</span>
                                            </div>
                                            <div class="text-end ps-3">
                                                {% if product.product.isPromotion %}
                                                    {% set itemPrice = ((product.product.price / 100) * (1 - (product.product.offPercent / 100))) * product.quantity %}
                                                {% else %}
                                                    {% set itemPrice = (product.product.price * product.quantity) / 100 %}
                                                {% endif %}
                                                <span
                                                    class="fw-bold fs-6 text-dark">{{ itemPrice | format_currency('XOF') }}</span>
                                            </div>
                                        </li>
                                        {% set total = total + itemPrice %}
                                    {% endfor %}
                                </ul>

                                <div class="mt-4 pt-2">
                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <span class="fs-5 fw-medium text-muted">Total final</span>
                                        <span
                                            class="fs-3 fw-bold text-primary">{{ total | format_currency('XOF') }}</span>
                                    </div>

                                    <button type="submit" class="btn btn-wb-checkout w-100 py-3 fs-5 fw-bold">
                                        Valider et payer
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            {{ form_end(form) }}
        </div>
    </section>


    <!--------------- checkout-section-end---------------->
{% endblock %}
