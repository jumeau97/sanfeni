    {#    mobile alert product added to cart #}
    <style>
        .mobile-popup {
            position: fixed;
            top: 20px; /* Positionnée en haut avec un petit écart */
            left: 15px;
            right: 15px;
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
            z-index: 10000; /* Doit être au-dessus de tout, même du header */

            /* On la cache au-dessus de la zone visible */
            transform: translateY(-150%);
